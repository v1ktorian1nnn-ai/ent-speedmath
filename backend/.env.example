# Скопируй этот файл в .env и заполни реальными значениями

# Строка подключения к PostgreSQL (например, из Neon: https://neon.tech)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Секрет для подписи JWT-токенов — вставь любую длинную случайную строку
JWT_SECRET="change-me-to-a-long-random-string"

# Порт сервера
PORT=4000

# Адрес фронтенда — нужен для настройки CORS
FRONTEND_ORIGIN="http://localhost:5173"
